{% extends "layouts/base.njk" %}

{% set pathPrefix = "../" %}

{% block body %}
<header class="post-hero" style="--post-accent: {{ color or gradTo }}; background: linear-gradient(150deg, {{ gradFrom }} 0%, {{ gradTo }} 80%);">
  <div class="container-fluid px-4">
    <div class="post-breadcrumb">
      <a href="../travel.html" data-i18n="nav.travel">Travel</a> <i class="fas fa-chevron-right"></i> <span>{{ label }}</span>
    </div>
    <div class="post-emoji">{{ emoji }}</div>
    <h1 class="display-4">
      <span data-lang-block="en">{{ heroTitleEn or title }}</span>
      <span data-lang-block="fr">{{ heroTitleFr or heroTitleEn or title }}</span>
    </h1>
    <p class="lead">
      <span data-lang-block="en">{{ heroSubtitleEn or heroSubtitle }}</span>
      <span data-lang-block="fr">{{ heroSubtitleFr or heroSubtitleEn or heroSubtitle }}</span>
    </p>
  </div>
</header>

<main id="main" role="main" style="--post-accent: {{ color or gradTo }};">
  <article class="py-5">
    <div class="container-fluid px-4">
      <div class="post-content">
        {% if status == "construction" %}
          <div class="text-center py-5">
            <i class="fas fa-hard-hat fa-3x mb-3" style="color:#d4a945;"></i>
            <h3 data-lang-block="en">Under Construction</h3>
            <h3 data-lang-block="fr">En construction</h3>
            <p class="text-muted" data-lang-block="en">The travel diary for {{ label }} is being written — check back soon.</p>
            <p class="text-muted" data-lang-block="fr">Le journal de voyage pour {{ labelFr or label }} est en cours de rédaction — revenez bientôt.</p>
          </div>
        {% else %}
          {{ content | safe }}
        {% endif %}
      </div>
    </div>
  </article>

  <section class="py-5 bg-light text-center">
    <div class="container-fluid px-4">
      <h4 class="mb-3">
        <span data-lang-block="en">Read more travel stories</span>
        <span data-lang-block="fr">Lire d'autres récits</span>
      </h4>
      <a href="../travel.html" class="btn btn-primary btn-lg">
        <i class="fas fa-arrow-left"></i>
        <span data-lang-block="en">All travel stories</span>
        <span data-lang-block="fr">Tous les récits</span>
      </a>
    </div>
  </section>
</main>
{% endblock %}

{% block scripts %}
<script src="{{ pathPrefix }}Scripts/places-config.js"></script>
<script src="{{ pathPrefix }}Scripts/places-ui.js" defer></script>
<script src="{{ pathPrefix }}Scripts/diary-lightbox.js" defer></script>
{% if journeyMap and journey %}
{# Scroll-following itinerary map (see Scripts/journey-map.js).
   Stops are projected from lat/lng at runtime; anchors are heading ids in the article. #}
<script>
window.__JOURNEY__ = {
  outline: {{ journeyMap | dump | safe }},
  stops: [
  {%- for s in journey %}
    { label: {{ s.label | dump | safe }}, lat: {{ s.lat }}, lng: {{ s.lng }}, anchor: {{ s.anchor | dump | safe }}{% if s.labelSide %}, labelSide: {{ s.labelSide | dump | safe }}{% endif %} }{% if not loop.last %},{% endif %}
  {%- endfor %}
  ],
  upcoming: [
  {%- for s in journeyUpcoming %}
    { label: {{ s.label | dump | safe }}, lat: {{ s.lat }}, lng: {{ s.lng }}{% if s.labelSide %}, labelSide: {{ s.labelSide | dump | safe }}{% endif %} }{% if not loop.last %},{% endif %}
  {%- endfor %}
  ]
};
</script>
<script src="{{ pathPrefix }}Scripts/journey-outlines/{{ journeyMap }}.js" defer></script>
<script src="{{ pathPrefix }}Scripts/journey-map.js" defer></script>
{% endif %}
<script>
  // Reveal diary sections as they scroll into view
  (function () {
    if (!('IntersectionObserver' in window)) return;
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
    var targets = document.querySelectorAll('.diary-day');
    var io = new IntersectionObserver(function (entries) {
      entries.forEach(function (entry) {
        if (entry.isIntersecting) {
          entry.target.classList.add('in-view');
          io.unobserve(entry.target);
        }
      });
    }, { threshold: 0.05, rootMargin: '0px 0px -40px 0px' });
    targets.forEach(function (el) {
      el.classList.add('reveal');
      io.observe(el);
    });
  })();
</script>
{% endblock %}
