---
permalink: /travel.html
pathPrefix: ""
title: "Travel Blog — Alexandre Bredillot"
description: "Travel stories, photographs and notes from the road by Alexandre Bredillot."
themeColor: "#000000"
ogDescription: "Travel stories, photographs and notes from the road."
---
{% extends "layouts/base.njk" %}

{% block head %}
    <meta name="keywords" content="Alexandre Bredillot, Travel Blog, Travel Stories, Photography">
    <meta property="twitter:card" content="summary_large_image">
    <meta property="twitter:url" content="{{ site.url }}/travel.html">
    <meta property="twitter:title" content="{{ title }}">
    <meta property="twitter:description" content="{{ ogDescription }}">
    <script src="https://unpkg.com/globe.gl/dist/globe.gl.min.js"></script>
{% endblock %}

{% block body %}
<header id="travel-hero" class="d-flex flex-column justify-content-center align-items-center text-center bg-primary text-white" style="min-height: 60vh; padding-top: 6rem; position: relative; overflow: hidden;">
  <div class="container-fluid px-4">
    <div class="travel-hero-icon mb-3"><i class="fas fa-globe-europe"></i></div>
    <h1 class="display-4 mb-2 text-white" data-i18n="travel.hero.title">Travel Blog</h1>
    <p class="lead mb-1" data-i18n="travel.hero.subtitle">Notes, photographs and impressions from the road</p>
    <p class="text-light mb-3" style="max-width: 700px; margin: 0 auto;" data-i18n="travel.hero.desc">
      A personal log of places that have shaped my perspective — cities, mountains, and quiet streets,
      told through short stories and field notes.
    </p>
    <div class="mt-3">
      <a href="#destinations" class="btn btn-light btn-lg"><i class="fas fa-book-open"></i> <span data-i18n="travel.hero.btn_browse">Browse Trips</span></a>
      <a href="#globe-section" class="btn btn-outline-light btn-lg ml-2"><i class="fas fa-globe"></i> <span data-i18n="travel.hero.btn_globe">Open Globe</span></a>
    </div>
  </div>
</header>

<main id="main" role="main">

  <section id="intro" class="py-5">
    <div class="container-fluid px-4">
      <h3 class="section-title" data-i18n="travel.intro.title">About this blog</h3>
      <p data-i18n="travel.intro.body">
        Beyond data and finance, travelling has always been the most reliable way I know to learn faster.
        This page collects short pieces from recent trips — what I saw, what surprised me, and the little
        practical things worth remembering. Posts are added gradually whenever a destination is worth writing about.
      </p>
    </div>
  </section>

  <section id="destinations" class="py-5">
    <div class="container-fluid px-4">
      <h3 class="section-title" data-i18n="travel.dest.title">Destinations</h3>
      <p class="mb-4 text-muted" data-i18n="travel.dest.subtitle">Click any trip to fly there on the globe below.</p>

      <h5 class="dest-subhead" data-i18n="travel.dest.recent">Recent trips</h5>
      <div class="row" id="dest-recent"></div>

      <h5 class="dest-subhead mt-5" data-i18n="travel.dest.by_continent">More trips by continent</h5>
      <div id="dest-continents" class="continent-list"></div>
    </div>
  </section>

  <section id="globe-section" class="globe-fullscreen-section">
    <div id="globeViz"></div>
    <div class="globe-hud">
      <span id="globe-hud-status" data-i18n="travel.globe.idle">Drag to spin · Click a destination above to take off</span>
    </div>
    <div id="globe-fade-overlay" class="globe-fade-overlay"></div>
  </section>

  <section id="travel-cta" class="py-5 bg-light">
    <div class="container-fluid px-4 text-center">
      <h3 class="section-title mb-3" data-i18n="travel.cta.title">Want to talk travel?</h3>
      <p class="mb-4" data-i18n="travel.cta.body">Recommendations, route ideas, or just sharing photos — happy to chat.</p>
      <a href="mailto:{{ site.email }}" class="btn btn-primary btn-lg">
        <i class="fas fa-envelope"></i> <span data-i18n="travel.cta.btn_email">Send a message</span>
      </a>
      <a href="index.html" class="btn btn-outline-primary btn-lg ml-2">
        <i class="fas fa-arrow-left"></i> <span data-i18n="travel.cta.btn_back">Back to portfolio</span>
      </a>
    </div>
  </section>

</main>
{% endblock %}

{% block scripts %}
<script>
  (function($){
    $(document).on('click','a.btn[href^="#"]', function(e){
      var hash = this.hash;
      if(!hash) return;
      var target = $(hash);
      if(target.length){
        e.preventDefault();
        $('html,body').animate({scrollTop: target.offset().top - 70}, 400);
      }
    });
  })(jQuery);
</script>

<script>
{# Trips derived at build time from front matter of each _src/travel/*.md file.
   Order = newest first (sorted by date in .eleventy.js).
   Construction stubs and published posts are both included. #}
window.__TRIPS__ = [
{%- for post in collections.trips -%}
  {%- set d = post.data %}
  {
    "id":        {{ d.slug | dump | safe }},
    "continent": {{ d.continent | dump | safe }},
    "label":     {{ d.label | dump | safe }},
    "emoji":     {{ d.emoji | dump | safe }},
    "title":     {{ (d.heroTitleEn or d.label) | dump | safe }},
    "date":      {{ d.dateLabel | dump | safe }},
    "lat":       {{ d.lat }},
    "lng":       {{ d.lng }},
    "color":     {{ d.color | dump | safe }},
    "gradFrom":  {{ d.gradFrom | dump | safe }},
    "gradTo":    {{ d.gradTo | dump | safe }},
    "href":      {{ ("travel/" + d.slug + ".html") | dump | safe }},
    "sub":       {{ d.sub | dump | safe }},
    "live":      {{ (d.live or false) | dump | safe }}
  }{% if not loop.last %},{% endif %}
{%- endfor %}
];
</script>

<script>
/* Destination cards — rendered independently of the globe so the page
   still works when the globe library fails to load. */
(function () {
  var TRIPS = window.__TRIPS__;
  var CONTINENTS = {{ continents | dump | safe }};

  function tr(key) { return (typeof window.tKey === 'function' ? window.tKey(key) : key); }
  function tripCount(n) { if (n === 1) return '1 ' + tr('travel.card.trip'); return n + ' ' + tr('travel.card.trips'); }

  function handleTripClick(trip) {
    if (typeof window.__flyToTrip === 'function') window.__flyToTrip(trip);
    else window.location.href = trip.href;
  }

  function buildBigCard(trip) {
    var card = document.createElement('div');
    card.className = 'col-md-6 col-lg-3 mb-4';
    var soonBadge = trip.live ? '' :
      '<span class="dest-card-soon">' + tr('travel.card.coming_soon') + '</span>';
    card.innerHTML =
      '<article class="dest-card ' + (trip.live ? 'clickable' : 'not-clickable') + '">' +
        '<div class="dest-card-cover" style="background:linear-gradient(135deg,' + trip.gradFrom + ',' + trip.gradTo + ')">' +
          '<span class="dest-card-emoji">' + trip.emoji + '</span>' +
          soonBadge +
        '</div>' +
        '<div class="dest-card-body">' +
          '<div class="dest-card-date">' + trip.date + '</div>' +
          '<h6 class="dest-card-title">' + trip.title + '</h6>' +
          '<p class="dest-card-sub">' + trip.sub + '</p>' +
        '</div>' +
      '</article>';
    if (trip.live) {
      card.querySelector('.dest-card').addEventListener('click', function () { handleTripClick(trip); });
    }
    return card;
  }

  function buildSmallCard(trip) {
    var el = document.createElement('div');
    el.className = 'dest-card-sm ' + (trip.live ? 'clickable' : 'not-clickable');
    var trailing = trip.live ?
      '<i class="fas fa-chevron-right dest-card-sm-caret"></i>' :
      '<span class="dest-card-sm-soon">' + tr('travel.card.coming_soon') + '</span>';
    el.innerHTML =
      '<div class="dest-card-sm-thumb" style="background:linear-gradient(135deg,' + trip.gradFrom + ',' + trip.gradTo + ')">' + trip.emoji + '</div>' +
      '<div class="dest-card-sm-info">' +
        '<div class="dest-card-sm-date">' + trip.date + '</div>' +
        '<div class="dest-card-sm-title">' + trip.label + ' — ' + trip.sub + '</div>' +
      '</div>' +
      trailing;
    if (trip.live) {
      el.addEventListener('click', function () { handleTripClick(trip); });
    }
    return el;
  }

  function renderRecent() {
    var recentEl = document.getElementById('dest-recent');
    if (!recentEl) return;
    recentEl.innerHTML = '';
    TRIPS.slice(0, 4).forEach(function (t) { recentEl.appendChild(buildBigCard(t)); });
  }

  function renderContinents() {
    var continentsEl = document.getElementById('dest-continents');
    if (!continentsEl) return;
    continentsEl.innerHTML = '';
    var remaining = TRIPS.slice(4);
    CONTINENTS.forEach(function (c) {
      var trips = remaining.filter(function (t) { return t.continent === c.id; });
      if (trips.length === 0) return;
      var block = document.createElement('div');
      block.className = 'continent-block';
      block.innerHTML =
        '<button class="continent-toggle" type="button" aria-expanded="false">' +
          '<i class="fas ' + c.icon + ' continent-icon"></i>' +
          '<span class="continent-name">' + c.name + '</span>' +
          '<span class="continent-count">' + tripCount(trips.length) + '</span>' +
          '<i class="fas fa-chevron-down continent-chevron"></i>' +
        '</button>' +
        '<div class="continent-content"><div class="continent-grid"></div></div>';
      var grid = block.querySelector('.continent-grid');
      trips.forEach(function (t) { grid.appendChild(buildSmallCard(t)); });
      var toggle = block.querySelector('.continent-toggle');
      var content = block.querySelector('.continent-content');
      toggle.addEventListener('click', function () {
        var open = block.classList.toggle('open');
        toggle.setAttribute('aria-expanded', open ? 'true' : 'false');
        content.style.maxHeight = open ? (grid.scrollHeight + 32) + 'px' : '0';
      });
      continentsEl.appendChild(block);
    });
  }

  function renderAll() { renderRecent(); renderContinents(); }
  renderAll();

  document.addEventListener('langchange', function () {
    renderAll();
    var statusEl = document.getElementById('globe-hud-status');
    if (statusEl && !window.__globeInFlight) statusEl.textContent = tr('travel.globe.idle');
  });
})();
</script>

<script>
/* ---- Globe (optional enhancement) ---- */
(function () {
  if (typeof Globe === 'undefined') return;

  var TRIPS = window.__TRIPS__;

  function tr(key) { return (typeof window.tKey === 'function' ? window.tKey(key) : key); }

  var container = document.getElementById('globeViz');
  if (!container) return;

  var globe = Globe()(container);
  globe
    .globeImageUrl('https://unpkg.com/three-globe/example/img/earth-blue-marble.jpg')
    .bumpImageUrl('https://unpkg.com/three-globe/example/img/earth-topology.png')
    .backgroundImageUrl('https://unpkg.com/three-globe/example/img/night-sky.png')
    .backgroundColor('rgba(0,0,0,0)')
    .atmosphereColor('#5ab3f0')
    .atmosphereAltitude(0.28)
    .arcsData([])
    .arcColor('color')
    .arcAltitudeAutoScale(1.5)
    .arcStroke(0.85)
    .arcDashLength(0.001)
    .arcDashGap(0.999)
    .arcDashAnimateTime(0)
    .pointsData(TRIPS.map(function (t) { return { lat: t.lat, lng: t.lng, color: t.color }; }))
    .pointColor('color')
    .pointAltitude(0.01)
    .pointRadius(0.45);

  globe.controls().autoRotate = true;
  globe.controls().autoRotateSpeed = 0.35;
  globe.controls().enableDamping = true;
  globe.controls().dampingFactor = 0.08;
  globe.pointOfView({ lat: 30, lng: 25, altitude: 2.1 });

  function easeInOutCubic(t) { return t < 0.5 ? 4 * t * t * t : 1 - Math.pow(-2 * t + 2, 3) / 2; }

  function getUserLoc() {
    return new Promise(function (resolve) {
      if (!navigator.geolocation) return resolve({ lat: 48.8566, lng: 2.3522 });
      navigator.geolocation.getCurrentPosition(
        function (p) { resolve({ lat: p.coords.latitude, lng: p.coords.longitude }); },
        function () { resolve({ lat: 48.8566, lng: 2.3522 }); },
        { timeout: 4000, maximumAge: 600000 }
      );
    });
  }

  function smoothScrollToGlobe() {
    var section = document.getElementById('globe-section');
    if (!section) return Promise.resolve();
    var top = section.getBoundingClientRect().top + window.pageYOffset;
    window.scrollTo({ top: top, behavior: 'smooth' });
    return new Promise(function (resolve) {
      var elapsed = 0;
      var iv = setInterval(function () {
        elapsed += 60;
        if (Math.abs(window.pageYOffset - top) < 4 || elapsed > 1400) { clearInterval(iv); resolve(); }
      }, 60);
    });
  }

  var animRaf = null;

  window.__flyToTrip = function (trip) {
    if (window.__globeInFlight) return;
    window.__globeInFlight = true;
    var statusEl = document.getElementById('globe-hud-status');
    if (statusEl) statusEl.textContent = tr('travel.globe.plotting') + trip.label + '…';

    smoothScrollToGlobe().then(function () { return getUserLoc(); }).then(function (origin) {
      globe.controls().autoRotateSpeed = 0.001;

      var arc = {
        startLat: origin.lat, startLng: origin.lng,
        endLat: trip.lat,     endLng: trip.lng,
        color: ['rgba(255,255,255,0.95)', trip.color]
      };
      globe.arcsData([arc]).arcDashLength(0.001).arcDashGap(0.999);

      var dlng = Math.abs(trip.lng - origin.lng);
      if (dlng > 180) dlng = 360 - dlng;
      var dlat = Math.abs(trip.lat - origin.lat);
      var span = Math.sqrt(dlat * dlat + dlng * dlng);
      var alt = span > 130 ? 4.2 : span > 90 ? 3.5 : span > 50 ? 3.0 : 2.8;

      globe.pointOfView({
        lat: (origin.lat + trip.lat) / 2,
        lng: (origin.lng + trip.lng) / 2,
        altitude: alt
      }, 900);

      var DURATION = 2400;
      var t0 = Date.now();

      function step() {
        var raw = Math.min((Date.now() - t0) / DURATION, 1);
        var e = easeInOutCubic(raw);
        globe.arcDashLength(Math.max(e, 0.001)).arcDashGap(Math.max(1 - e, 0));
        if (raw < 1) {
          animRaf = requestAnimationFrame(step);
        } else {
          globe.controls().autoRotate = false;
          var overlay = document.getElementById('globe-fade-overlay');
          if (overlay) { overlay.style.background = trip.gradTo; overlay.style.opacity = '1'; }
          if (statusEl) statusEl.textContent = tr('travel.globe.landing') + trip.label + '…';
          setTimeout(function () { window.location.href = trip.href; }, 650);
        }
      }
      animRaf = requestAnimationFrame(step);
    });
  };

  function onResize() {
    if (container.offsetWidth > 0) {
      globe.width(container.offsetWidth).height(container.offsetHeight);
    }
  }
  window.addEventListener('resize', onResize);
  setTimeout(onResize, 100);
})();
</script>
{% endblock %}
